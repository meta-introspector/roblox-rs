oo);\n}\n\nfn main() {\n    // Calling the method is still fine, as i32 implements Debug.\n    some_func(5i32);\n\n    // This would fail to compile now:\n    // struct WithoutDebug;\n    // some_func(WithoutDebug);\n}\n```\n\nRust only looks at the signature of the called function, as such it must\nalready specify all requirements that will be used for every type parameter.\n"},"level":"error","spans":[{"file_name":"roblox-rs-ecs/src/system.rs","byte_start":7627,"byte_end":7664,"line_start":288,"line_end":288,"column_start":19,"column_end":56,"is_primary":true,"text":[{"text":"    type System = FunctionSystem<F, (Res1, Res2, Res3)>;","highlight_start":19,"highlight_end":56}],"label":"`Res1` cannot be sent between threads safely","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[{"message":"required because it appears within the type `(Res1, Res2, Res3)`","code":null,"level":"note","spans":[],"children":[],"rendered":null},{"message":"required because it appears within the type `PhantomData<(Res1, Res2, Res3)>`","code":null,"level":"note","spans":[{"file_name":"/Users/dunno/.rustup/toolchains/stable-aarch64-apple-darwin/lib/rustlib/src/rust/library/core/src/marker.rs","byte_start":29041,"byte_end":29052,"line_start":757,"line_end":757,"column_start":12,"column_end":23,"is_primary":true,"text":[{"text":"pub struct PhantomData<T: ?Sized>;","highlight_start":12,"highlight_end":23}],"label":null,"suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[],"rendered":null},{"message":"required because it appears within the type `FunctionSystem<F, (Res1, Res2, Res3)>`","code":null,"level":"note","spans":[{"file_name":"roblox-rs-ecs/src/system.rs","byte_start":1098,"byte_end":1112,"line_start":39,"line_end":39,"column_start":12,"column_end":26,"is_primary":true,"text":[{"text":"pub struct FunctionSystem<F, Params> {","highlight_start":12,"highlight_end":26}],"label":null,"suggested_replacement":null