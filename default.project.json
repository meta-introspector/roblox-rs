{
  "name": "monster-gyroscope",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "TweenServiceV2": {
        "$path": "vendor/TweenServiceV2/ReplicatedTweening.luau"
      },
      "GyroscopeConfig": {
        "$path": "src/ReplicatedStorage/GyroscopeConfig.lua"
      }
    },

    "ServerScriptService": {
      "$path": "src/ServerScriptService"
    },

    "StarterGui": {
      "GyroscopeUI": {
        "$path": "src/StarterGui/GyroscopeUI"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "$path": "src/StarterPlayerScripts"
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [0.04, 0.04, 0.07],
          "Locked": true,
          "Position": [0, -10, 0],
          "Size": [512, 20, 512]
        }
      }
    },

    "Lighting": {
      "$properties": {
        "Ambient": [0.02, 0.02, 0.05],
        "Brightness": 1,
        "GlobalShadows": true,
        "Technology": "Future"
      }
    }
  }
}
